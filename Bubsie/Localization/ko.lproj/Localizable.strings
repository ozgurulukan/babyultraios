"transform.consent_subtitle" = "Before you upload, please review the following information about how your data will be handled:";
"transform.consent_title" = "AI Photo Processing Consent";
"transform.consent_section1_title" = "What Data We Collect & Send";
"transform.consent_section1_body" = "When you use this feature, the following data is sent to our servers and to our third-party AI provider:\n\n• Your uploaded photo (which may contain face data such as facial features and facial geometry)\n• Text prompts and template instructions that describe the desired transformation\n• Technical parameters (aspect ratio, model settings)\n• If the template involves family members, each family member's photo is sent separately";
"transform.consent_section2_title" = "Who Receives Your Data";
"transform.consent_section2_body" = "Your data is sent to fal.ai (FAL Technologies, Inc.), a third-party AI service provider that performs the image and video generation on secure servers in the US and EU. fal.ai does not use your data to train AI models without your explicit consent.";
"transform.consent_section3_title" = "How Your Data Is Used & Stored";
"transform.consent_section3_body" = "Your photo and data are used solely to generate the AI transformation you requested (e.g., style transfer, face swap, avatar creation, animated videos, photo enhancement). No other use is made of your data.\n\n• Your photo is stored on our secure servers (Cloudflare R2) and automatically deleted within 30 days.\n• AI-generated results are kept for up to 90 days or until you delete them.\n• If you delete your account, all data is permanently removed within 48 hours.";
"transform.consent_section4_title" = "Your Confirmation";
"transform.consent_section4_body" = "By tapping \"I Agree — Continue\" below, you confirm that:\n\n• The photos you upload are yours or you have parental permission to use them.\n• You are an adult (18+) using this app.\n• You will not upload someone else's child without their permission.\n• You consent to your photo and the data described above being sent to our servers and to fal.ai for AI processing.";
