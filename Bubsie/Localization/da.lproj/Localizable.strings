"transform.consent_subtitle" = "Før du uploader, bedes du gennemgå følgende oplysninger om, hvordan dine data vil blive håndteret:";
"transform.consent_title" = "Samtykke til AI-fotobehandling";
"transform.consent_section1_title" = "Hvilke data vi indsamler og sender";
"transform.consent_section1_body" = "Når du bruger denne funktion, sendes følgende data til vores servere og til vores tredjeparts AI-udbyder:\n\n• Dit uploadede foto (som kan indeholde ansigtsdata såsom ansigtstræk og ansigtsgeometri)\n• Tekstprompts og skabeloninstruktioner, der beskriver den ønskede transformation\n• Tekniske parametre (billedformat, modelindstillinger)\n• Hvis skabelonen involverer familiemedlemmer, sendes hvert familiemedlems foto separat";
"transform.consent_section2_title" = "Hvem modtager dine data";
"transform.consent_section2_body" = "Dine data sendes til fal.ai (FAL Technologies, Inc.), en tredjeparts AI-udbyder, der udfører billed- og videogenerering på sikre servere i USA og EU. fal.ai bruger ikke dine data til at træne AI-modeller uden dit udtrykkelige samtykke.";
"transform.consent_section3_title" = "Hvordan dine data bruges og opbevares";
"transform.consent_section3_body" = "Dit foto og dine data bruges udelukkende til at generere den AI-transformation, du har anmodet om (f.eks. stiloverførsel, ansigtsbytte, avataroprettelse, animerede videoer, fotoforbedring). Der foretages ingen anden brug af dine data.\n\n• Dit foto gemmes på vores sikre servere (Cloudflare R2) og slettes automatisk inden for 30 dage.\n• AI-genererede resultater opbevares i op til 90 dage eller indtil du sletter dem.\n• Hvis du sletter din konto, fjernes alle data permanent inden for 48 timer.";
"transform.consent_section4_title" = "Din bekræftelse";
"transform.consent_section4_body" = "Ved at trykke på \"Jeg er enig — Fortsæt\" nedenfor bekræfter du, at:\n\n• De fotos, du uploader, er dine, eller at du har forældretilladelse til at bruge dem.\n• Du er en voksen (18+), der bruger denne app.\n• Du vil ikke uploade en andens barn uden deres tilladelse.\n• Du samtykker til, at dit foto og de ovennævnte data sendes til vores servere og til fal.ai til AI-behandling.";
