"transform.consent_privacy_link" = "Baca Dasar Privasi penuh kami";
"transform.consent_subtitle" = "Sebelum anda memuat naik, sila semak maklumat berikut tentang bagaimana data anda akan diuruskan:";
"transform.consent_title" = "Persetujuan Pemprosesan Foto AI";
"transform.consent_section1_title" = "Data Apa yang Kami Kumpulkan & Hantar";
"transform.consent_section1_body" = "Apabila anda menggunakan ciri ini, data berikut dihantar ke pelayan kami dan ke penyedia AI pihak ketiga kami:\n\n• Foto anda yang dimuat naik (yang mungkin mengandungi data wajah seperti ciri wajah dan geometri wajah)\n• Prompt teks dan arahan templat yang menerangkan transformasi yang dikehendaki\n• Parameter teknikal (nisbah aspek, tetapan model)\n• Jika templat melibatkan ahli keluarga, foto setiap ahli keluarga dihantar secara berasingan";
"transform.consent_section2_title" = "Siapa yang Menerima Data Anda";
"transform.consent_section2_body" = "Data anda dihantar ke fal.ai (FAL Technologies, Inc.), penyedia perkhidmatan AI pihak ketiga yang melakukan penjanaan imej dan video di pelayan selamat di AS dan EU. fal.ai tidak menggunakan data anda untuk melatih model AI tanpa persetujuan eksplisit anda.";
"transform.consent_section3_title" = "Bagaimana Data Anda Digunakan & Disimpan";
"transform.consent_section3_body" = "Foto dan data anda digunakan semata-mata untuk menjana transformasi AI yang anda minta (cth. style transfer, face swap, avatar creation, animated videos, photo enhancement). Tiada penggunaan lain ke atas data anda.\n\n• Foto anda disimpan di pelayan selamat kami (Cloudflare R2) dan dipadamkan secara automatik dalam masa 30 hari.\n• Hasil yang dijana AI disimpan sehingga 90 hari atau sehingga anda memadamkannya.\n• Jika anda memadamkan akaun anda, semua data akan dibuang secara kekal dalam masa 48 jam.";
"transform.consent_section4_title" = "Pengesahan Anda";
"transform.consent_section4_body" = "Dengan mengetuk \"Saya Setuju — Teruskan\" di bawah, anda mengesahkan bahawa:\n\n• Foto yang anda muat naik adalah milik anda atau anda mempunyai kebenaran ibu bapa untuk menggunakannya.\n• Anda adalah dewasa (18+) yang menggunakan aplikasi ini.\n• Anda tidak akan memuat naik kanak-kanak orang lain tanpa kebenaran mereka.\n• Anda bersetuju foto anda dan data yang diterangkan di atas dihantar ke pelayan kami dan ke fal.ai untuk pemprosesan AI.";
