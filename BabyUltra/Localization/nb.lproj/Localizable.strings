"transform.consent_subtitle" = "Før du laster opp, vennligst gjennomgå følgende informasjon om hvordan dataene dine vil bli håndtert:";
"transform.consent_title" = "Samtykke til AI-bildebehandling";
"transform.consent_section1_title" = "Hvilke data vi samler inn og sender";
"transform.consent_section1_body" = "Når du bruker denne funksjonen, sendes følgende data til serverne våre og til vår tredjeparts AI-tilbyder:\n\n• Det opplastede bildet ditt (som kan inneholde ansiktsdata som ansiktstrekk og ansiktsgeometri)\n• Tekstprompts og malinstruksjoner som beskriver den ønskede transformasjonen\n• Tekniske parametre (sideforhold, modellinnstillinger)\n• Hvis malen involverer familiemedlemmer, sendes hvert familiemedlems bilde separat";
"transform.consent_section2_title" = "Hvem mottar dataene dine";
"transform.consent_section2_body" = "Dataene dine sendes til fal.ai (FAL Technologies, Inc.), en tredjeparts AI-tjenesteleverandør som utfører bilde- og videogenerering på sikre servere i USA og EU. fal.ai bruker ikke dataene dine til å trene AI-modeller uten ditt uttrykkelige samtykke.";
"transform.consent_section3_title" = "Hvordan dataene dine brukes og lagres";
"transform.consent_section3_body" = "Bildet ditt og dataene dine brukes utelukkende til å generere AI-transformasjonen du ba om (f.eks. stiloverføring, ansiktsbytte, avataroppretting, animerte videoer, bildeforbedring). Ingen annen bruk gjøres av dataene dine.\n\n• Bildet ditt lagres på våre sikre servere (Cloudflare R2) og slettes automatisk innen 30 dager.\n• AI-genererte resultater beholdes i opptil 90 dager eller til du sletter dem.\n• Hvis du sletter kontoen din, fjernes alle data permanent innen 48 timer.";
"transform.consent_section4_title" = "Din bekreftelse";
"transform.consent_section4_body" = "Ved å trykke på \"Jeg er enig — Fortsett\" nedenfor bekrefter du at:\n\n• Bildene du laster opp, er dine, eller at du har foreldretillatelse til å bruke dem.\n• Du er en voksen (18+) som bruker denne appen.\n• Du vil ikke laste opp noen andres barn uten deres tillatelse.\n• Du samtykker til at bildet ditt og dataene beskrevet ovenfor sendes til serverne våre og til fal.ai for AI-behandling.";
